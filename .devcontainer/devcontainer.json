// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/docker-existing-dockerfile
{
	"name": "jdhp-slides-vscode-devcontainer",
	"build": {
		// Sets the run context to the .devcontainer folder.
		// Note: The specified directory is relative to the ".devcontainer/" directory.
		"context": ".",
		// Update the 'dockerFile' property if you aren't using the standard 'Dockerfile' filename.
		// Note: The specified directory is relative to the ".devcontainer/" directory.
		"dockerfile": "./Containerfile"
	},

	// Declare environment variables
	// C.f. https://code.visualstudio.com/remote/advancedcontainers/environment-variables#_option-2-use-an-env-file
	// "runArgs": [
	// 	"--env-file",
	// 	".devcontainer/devcontainer.env"
	// ],

	// "containerEnv": {},

	// Features to add to the dev container. More info: https://containers.dev/features.
	// "features": {},

	// Use 'forwardPorts' to make a list of ports inside the container available locally.
	// "forwardPorts": [
	// 	5173,          // SvelteKit dev server
	// ],

	// Use 'mounts' to mount a host path or volume into the container.
	"mounts": [
		{
			// "source": "claude-code-home",       // My personal Claude Code subscription
			"source": "claude-code-home-accenta",  // Accenta's Claude Code subscription
			"target": "/home/user",
			"type": "volume"
		}
	],

	// Install the development dependencies once the container is created.
	"postCreateCommand": "npm install",

	// Unlike postCreateCommand (which only runs once), postStartCommand runs every time the
	// container starts. There is no container init system (no systemd) to auto-start services,
	// so this starts the dedicated dev PostgreSQL cluster (initializing it on first run) and
	// the dev Redis server as the devcontainer user. Both are meant to stay up for the whole
	// lifetime of the container -- this is throwaway dev data, so there is no matching "stop" step.
	"postStartCommand": "bash .devcontainer/postgres-start.sh && bash .devcontainer/redis-start.sh",

	// Configure tool-specific properties.
	"customizations": {
		"vscode": {
			"settings": {},
			"extensions": [
				"anthropic.claude-code",  // Claude Code extension for VS Code (https://marketplace.visualstudio.com/items?itemName=anthropic.claude-code)
				"charliermarsh.ruff",
				"ms-python.debugpy",
				"ms-python.isort",
				"ms-python.mypy-type-checker",
				"ms-python.python",
				"ms-python.vscode-pylance",
				"svelte.svelte-vscode"
			]
		}
	},

	// Uncomment to connect as an existing user other than the container default. More info: https://aka.ms/dev-containers-non-root.
	"remoteUser": "user"
}
